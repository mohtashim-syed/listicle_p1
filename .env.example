# Copy this file to .env and fill in your own values.
#
# Option A — hosted provider (Railway, Neon, Supabase, etc.):
#   set a single connection string. This takes precedence if present.
# DATABASE_URL=postgres://user:password@host:5432/dbname

# Option B — local Postgres: set the individual variables.
PGHOST=localhost
PGPORT=5432
PGUSER=your_username
PGPASSWORD=your_password
PGDATABASE=listicle

# Set to "true" when connecting to a hosted DB that requires SSL.
PGSSL=false
